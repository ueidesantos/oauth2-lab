@page "/auth/error"
@model OAuth2Lab.Web.Features.Auth.Error.AuthErrorModel
@{
    ViewData["Title"] = "Erro de Autenticação";
    Layout = "~/Shared/Views/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
    <div class="max-w-lg w-full space-y-6">
        <div class="text-center">
            <div class="text-6xl mb-4">⚠️</div>
            <h1 class="text-2xl font-bold text-gray-900">Erro de Autenticação</h1>
            <p class="mt-2 text-gray-500 text-sm">Algo deu errado durante o processo de login.</p>
        </div>

        <div class="bg-white rounded-2xl shadow-md p-6 space-y-4">
            <div>
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Mensagem</span>
                <p class="mt-1 text-gray-800 font-medium">@Model.ErrorMessage</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorCode))
            {
                <div>
                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Código</span>
                    <p class="mt-1 font-mono text-sm text-red-600">@Model.ErrorCode</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorDescription))
            {
                <div>
                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Descrição</span>
                    <p class="mt-1 text-sm text-gray-700">@Model.ErrorDescription</p>
                </div>
            }

            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-sm text-blue-800 space-y-1">
                <p class="font-semibold">Possíveis causas:</p>
                <ul class="list-disc list-inside space-y-1 text-blue-700">
                    <li>ClientId ou ClientSecret inválidos</li>
                    <li>Redirect URI não configurada no provedor</li>
                    <li>Usuário cancelou o processo de login</li>
                    <li>Escopos não permitidos para a aplicação</li>
                </ul>
            </div>
        </div>

        <div class="text-center">
            <a href="/" class="inline-flex items-center gap-2 text-sm text-blue-600 hover:underline">
                ← Voltar para o login
            </a>
        </div>
    </div>
</div>
